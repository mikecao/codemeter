{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "codemeter",
  "version": "0.1.1",
  "identifier": "com.codemeter.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5183",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "codemeter",
        "width": 400,
        "height": 380,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
      "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
